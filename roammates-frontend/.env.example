# ==========================================
# ROAMMATES FRONTEND - ENVIRONMENT VARIABLES
# ==========================================

# 1. OpenWeatherMap API
# Used for the Weather Widget on the Trip Details page.
# Get a free API key at: https://home.openweathermap.org/users/sign_up
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# 2. ExchangeRate-API
# Used for the Currency Converter Widget.
# Get a free API key at: https://www.exchangerate-api.com/
VITE_EXCHANGERATE_API_KEY=your_exchangerate_api_key_here

# 3. Backend URL
# The base URL for the Spring Boot Backend API
VITE_API_BASE_URL=http://localhost:8080
